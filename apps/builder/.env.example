VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_GITHUB_CLIENT_ID=your-github-oauth-app-client-id

# Sentry error monitoring -- leave blank to disable (Sentry.init() no-ops
# safely with an empty dsn). Set to this app's Sentry project DSN to enable.
VITE_SENTRY_DSN=

# Server-side only (set in Vercel project settings, never exposed to the client) --
# used by api/github/callback.js to exchange the OAuth code for an access token.
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret
